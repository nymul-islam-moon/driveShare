# Frontend Configuration

# API Base URL (where the FastAPI backend is running)
REACT_APP_API_URL=http://localhost:9999

# Google OAuth Configuration
# IMPORTANT: Copy the SAME values from your backend/.env file
# Replace these with your actual Google Cloud credentials
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_FROM_BACKEND
REACT_APP_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_FROM_BACKEND
